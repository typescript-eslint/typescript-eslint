{
  "name": "scope-manager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "packages/scope-manager",
  "sourceRoot": "packages/scope-manager/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist", "{projectRoot}/_ts4.3"],
      "options": {
        "parallel": false,
        "commands": [
          { "command": "rimraf _ts4.3/" },
          { "command": "yarn run build" }
        ]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "cwd": "{projectRoot}",
        "commands": [
          { "command": "tsc -p tsconfig.build.json --noEmit" },
          { "command": "tsc -p tsconfig.spec.json --noEmit" }
        ]
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "parallel": true,
        "commands": [
          { "command": "yarn run clean" },
          { "command": "yarn run postclean" }
        ]
      }
    },
    "clean-fixtures": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "cwd": "{projectRoot}",
        "commands": [{ "command": "yarn run clean-fixtures" }]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
