{
  "name": "scope-manager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "packages/scope-manager",
  "sourceRoot": "packages/scope-manager/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "cwd": "{projectRoot}",
        "commands": [
          { "command": "tsc -p tsconfig.build.json --noEmit" },
          { "command": "tsc -p tsconfig.spec.json --noEmit" }
        ]
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "parallel": true,
        "commands": [
          { "command": "tsc -b tsconfig.build.json --clean" },
          { "command": "rimraf dist/ _ts4.3/ coverage/" }
        ]
      }
    },
    "clean-fixtures": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          { "command": "rimraf -g \"./src/**/fixtures/**/snapshots\"" }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
