{
  "name": "scope-manager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "packages/scope-manager",
  "sourceRoot": "packages/scope-manager/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist", "{projectRoot}/_ts4.3"],
      "options": {
        "parallel": false,
        "cwd": "packages/scope-manager",
        "commands": [
          "rimraf _ts4.3",
          "tsc -b tsconfig.build.json",
          "downlevel-dts dist _ts4.3/dist --to=4.3"
        ]
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "parallel": true,
        "commands": [
          { "command": "tsc -b tsconfig.build.json --clean" },
          { "command": "rimraf dist/ _ts4.3/ coverage/" }
        ]
      }
    },
    "clean-fixtures": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          { "command": "rimraf -g \"./src/**/fixtures/**/snapshots\"" }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vite:test"
    }
  }
}
