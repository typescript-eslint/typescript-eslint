{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "language": "en",
  "ignorePaths": [
    ".github/workflows/**",
    ".vscode/*.json",
    "**/*.{json,snap,shot}",
    "**/*.{css,svg,xml}",
    "pnpm-lock.yaml",
    "**/**/CHANGELOG.md",
    "docs/packages/*/generated/**",
    "packages/scope-manager/src/lib/**",
    "packages/types/src/lib.ts",
    "packages/typescript-estree/src/jsx/xhtml-entities.ts",
    "**/**/TSLINT_RULE_ALTERNATIVES.md",
    "**/coverage/**",
    "**/dist/**",
    "**/fixtures/**",
    "**/tests/**",
    "**/__tests__/**",
    "**/*.{test,spec}.{ts,mts,cts,tsx,js,cjs,mjs,jsx}",
    "**/node_modules/**",
    "packages/website/.docusaurus/**",
    "packages/website/build/**",
    "packages/website/src/vendor/**"
  ],
  "dictionaries": [
    "typescript",
    "softwareTerms",
    "node",
    "en_US",
    "npm",
    "misc",
    "filetypes"
  ],
  "ignoreRegExpList": [
    "/\\.\\/docs\\/rules\\/[^.]*.md/",
    "/@typescript-eslint\\/[a-z-]+/",
    "/\\.all-contributorsrc/",
    "/TS[A-Z0-9][^\\s]*/",
    "/(?<=[A-Za-z])(?:dont|didnt)|(?:dont|didnt)(?=[A-Z])/i",
    "\\(#.+?\\)"
  ],
