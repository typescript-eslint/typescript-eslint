{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "nxCloudAccessToken": "YjIzMmMxMWItMjhiMS00NWY2LTk1NWYtYWU3YWQ0YjE4YjBlfHJlYWQ=",
  "release": {
    "projects": [
      "!repo",
      "!website*",
      "!integration-tests",
      "!eslint-plugin-internal"
    ],
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github",
        "renderer": "{workspaceRoot}/tools/release/changelog-renderer"
      },
      "projectChangelogs": {
        "renderer": "{workspaceRoot}/tools/release/changelog-renderer"
      }
    },
    "version": {
      "conventionalCommits": true
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        {
          "target": "build",
          "dependencies": true
        }
      ],
      "inputs": [
        {
          "input": "production"
        },
        {
          "input": "production",
          "dependencies": true
        }
      ],
      "outputs": ["{projectRoot}/dist"],
      "cache": true,
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/jest.config.js",
        "{workspaceRoot}/jest.config.base.js"
      ],
      "outputs": ["{projectRoot}/coverage"],
      "cache": true
    },
    "@nx/jest:jest": {
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/jest.config.js",
        "{workspaceRoot}/jest.config.base.js"
      ],
      "outputs": ["{projectRoot}/coverage"],
      "cache": true,
      "options": {
        "jestConfig": "{projectRoot}/jest.config.js",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "dependsOn": [
        {
          "projects": [
            "eslint-plugin",
            "eslint-plugin-internal",
            "typescript-eslint"
          ],
          "target": "build"
        }
      ],
      "options": {
        "noEslintrc": true,
        "cache": true,
        "eslintConfig": "{workspaceRoot}/eslint.config.js"
      },
      "inputs": [
        {
          "input": "default"
        },
        {
          "fileset": "{workspaceRoot}/eslint.config.js"
        },
        {
          "fileset": "{workspaceRoot}/eslint.config.mjs"
        },
        {
          "dependentTasksOutputFiles": "**/*.js",
          "transitive": false
        }
      ],
      "outputs": ["{options.outputFile}"],
      "cache": true
    }
  },
  "namedInputs": {
    "default": [
      {
        "fileset": "{projectRoot}/**/*"
      },
      {
        "input": "sharedGlobals"
      }
    ],
    "sharedGlobals": [
      {
        "fileset": "{workspaceRoot}/.github/workflows/ci.yml"
      },
      {
        "runtime": "node -v"
      },
      {
        "runtime": "echo $NETLIFY"
      },
      {
        "runtime": "yarn -v"
      },
      {
        "fileset": "{workspaceRoot}/yarn.lock"
      }
    ],
    "production": [
      {
        "input": "default"
      },
      {
        "fileset": "!{projectRoot}/**/?(*.)+(test).[jt]s?(x)?(.snap)"
      },
      {
        "fileset": "!{projectRoot}/tsconfig.spec.json"
      },
      {
        "fileset": "!{projectRoot}/jest.config.[jt]s"
      },
      {
        "fileset": "!{projectRoot}/src/test-setup.[jt]s"
      },
      {
        "fileset": "!{projectRoot}/vitest.config.m[jt]s"
      }
    ]
  }
}
